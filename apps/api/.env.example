# API-level env (also see root .env.example for the full list)
APP_ENV=dev
APP_SECRET=change-me
DATABASE_URL=postgresql://careeros:careeros@postgres:5432/careeros
REDIS_URL=redis://redis:6379/0
OLLAMA_BASE_URL=http://ollama:11434
MODEL_TIER=B
CLOUD_FALLBACK_ENABLED=false
CLOUD_PROVIDER=groq
GROQ_API_KEY=
BLOCK_CLOUD_PERSONAL_DATA=true

# --- Communication channels (CareerOS-owned shared bots) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=CareerOSBot
WHATSAPP_NUMBER=

# --- v2 Intelligence: Qdrant vector store ---
# Local: docker run -p 6333:6333 qdrant/qdrant
QDRANT_URL=http://localhost:6333
# Leave blank for local Qdrant (no auth required by default)
QDRANT_API_KEY=
